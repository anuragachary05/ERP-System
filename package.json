{
  "name": "erp-mern",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "start": "npm run start --workspace=server",
    "install:all": "npm install --workspace=server && npm install --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
